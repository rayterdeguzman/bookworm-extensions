{
  "id": "novelfire",
  "name": "NovelFire",
  "version": 1,
  "lang": "en",
  "baseUrl": "https://novelfire.net",
  "contentType": "text",
  "isApi": false,
  "supportsLatest": true,
  "useWebView": true,
  "rateLimit": {
    "requests": 1,
    "perSeconds": 2
  },
  "headers": {
    "Referer": "https://novelfire.net/"
  },
  "filters": [
    {
      "name": "Genre",
      "type": "select",
      "options": [
        "All",
        "Action", "Adult", "Adventure", "Comedy", "Drama",
        "Eastern", "Ecchi", "Fan-fiction", "Fantasy", "Game",
        "Gender Bender", "Harem", "Historical", "Horror", "Isekai",
        "Josei", "Magical Realism", "Martial Arts", "Mature", "Mecha",
        "Military", "Modern Life", "Mystery", "Psychological",
        "Reincarnation", "Romance", "School Life", "Sci-fi", "Seinen",
        "Shoujo", "Shounen", "Slice of Life", "Smut", "Sports",
        "Supernatural", "System", "Thriller", "Tragedy", "Urban",
        "Video Games", "War", "Wuxia", "Xianxia", "Xuanhuan",
        "Yaoi", "Yuri"
      ],
      "values": [
        "all",
        "action", "adult", "adventure", "comedy", "drama",
        "eastern", "ecchi", "fan-fiction", "fantasy", "game",
        "gender-bender", "harem", "historical", "horror", "isekai",
        "josei", "magical-realism", "martial-arts", "mature", "mecha",
        "military", "modern-life", "mystery", "psychological",
        "reincarnation", "romance", "school-life", "sci-fi", "seinen",
        "shoujo", "shounen", "slice-of-life", "smut", "sports",
        "supernatural", "system", "thriller", "tragedy", "urban",
        "video-games", "war", "wuxia", "xianxia", "xuanhuan",
        "yaoi", "yuri"
      ],
      "defaultValue": "all"
    },
    {
      "name": "Sort By",
      "type": "select",
      "options": ["Popular", "New", "Latest Release"],
      "values": ["popular", "new", "latest-release"],
      "defaultValue": "popular"
    },
    {
      "name": "Status",
      "type": "select",
      "options": ["All", "Completed", "Ongoing"],
      "values": ["all", "completed", "ongoing"],
      "defaultValue": "all"
    },
    {
      "name": "Type",
      "type": "select",
      "options": ["All", "Chinese Novel", "Korean Novel", "Japanese Novel"],
      "values": ["all-novel", "chinese-novel", "korean-novel", "japanese-novel"],
      "defaultValue": "all-novel"
    }
  ],
  "endpoints": {
    "search": {
      "path": "/genre-{Genre}/sort-{Sort By}/status-{Status}/{Type}",
      "isApi": false,
      "params": {
        "page": "{page}"
      },
      "waitForSelector": ".novel-list .novel-item",
      "selector": {
        "list": ".novel-list .novel-item",
        "id": "a@href | regex:/\\/book\\/([^\\/]+)/",
        "title": ".novel-title",
        "coverUrl": "img@data-src"
      },
      "nextPageSelector": "ul.pagination li.active + li a"
    },
    "popular": {
      "path": "/genre-{Genre}/sort-popular/status-{Status}/{Type}",
      "isApi": false,
      "params": {
        "page": "{page}"
      },
      "waitForSelector": ".novel-list .novel-item",
      "selector": {
        "list": ".novel-list .novel-item",
        "id": "a@href | regex:/\\/book\\/([^\\/]+)/",
        "title": ".novel-title",
        "coverUrl": "img@data-src"
      },
      "nextPageSelector": "ul.pagination li.active + li a"
    },
    "latest": {
      "path": "/genre-all/sort-latest-release/status-all/all-novel",
      "isApi": false,
      "params": {
        "page": "{page}"
      },
      "waitForSelector": ".novel-list .novel-item",
      "selector": {
        "list": ".novel-list .novel-item",
        "id": "a@href | regex:/\\/book\\/([^\\/]+)/",
        "title": ".novel-title",
        "coverUrl": "img@data-src"
      },
      "nextPageSelector": "ul.pagination li.active + li a"
    },
    "details": {
      "path": "/book/{seriesId}",
      "isApi": false,
      "selector": {
        "title": ".novel-title",
        "coverUrl": "figure.cover img@data-src",
        "author": "span[itemprop='author']",
        "description": ".summary .content",
        "status": ".header-stats .completed, .header-stats .ongoing",
        "tags": ".categories a, .tags a"
      }
    },
    "chapters": {
      "path": "/book/{seriesId}/chapters",
      "isApi": false,
      "waitForSelector": "ul.chapter-list",
      "selector": {
        "list": "ul.chapter-list li",
        "id": "a@href | regex:/([^\\/]+)\\/?$/",
        "title": ".chapter-title"
      },
      "nextPageSelector": "ul.pagination li.active + li a"
    },
    "content": {
      "path": "/book/{seriesId}/{chapterSlug}",
      "isApi": false,
      "waitForSelector": ".chapter-content",
      "selector": {
        "title": ".chapter-title",
        "content": ".chapter-content"
      },
      "contentRemoveSelectors": [
        "script",
        "style",
        "noscript",
        "iframe",
        ".adsbox",
        ".ad-container",
        ".ads",
        ".hidden",
        "div.ad",
        "ins.adsbygoogle",
        "nav.links",
        ".chapter-end",
        ".report-box"
      ]
    }
  }
}
