{
  "id": "novelbin",
  "name": "NovelBin",
  "version": 11,
  "lang": "en",
  "baseUrl": "https://novelbin.com",
  "contentType": "text",
  "isApi": false,
  "supportsLatest": true,
  "useWebView": true,
  "rateLimit": {
    "requests": 1,
    "perSeconds": 1
  },
  "headers": {
    "Referer": "https://novelbin.com/"
  },
  "filters": [
    {
      "name": "Sort",
      "type": "select",
      "options": ["Popular", "Latest", "New", "Completed", "Ongoing"],
      "values": ["top-view-novel", "latest", "new-novel", "completed", "ongoing"],
      "defaultValue": "top-view-novel"
    },
    {
      "name": "Genre",
      "type": "multiSelect",
      "options": [
        "Action", "Adventure", "Comedy", "Drama", "Ecchi",
        "Fantasy", "Harem", "Historical", "Horror", "Josei",
        "Martial Arts", "Mature", "Mecha", "Mystery", "Psychological",
        "Romance", "School Life", "Sci-fi", "Seinen", "Shoujo",
        "Shounen", "Slice of Life", "Smut", "Sports", "Supernatural",
        "Tragedy", "Wuxia", "Xianxia", "Xuanhuan"
      ],
      "values": [
        "action", "adventure", "comedy", "drama", "ecchi",
        "fantasy", "harem", "historical", "horror", "josei",
        "martial-arts", "mature", "mecha", "mystery", "psychological",
        "romance", "school-life", "sci-fi", "seinen", "shoujo",
        "shounen", "slice-of-life", "smut", "sports", "supernatural",
        "tragedy", "wuxia", "xianxia", "xuanhuan"
      ],
      "defaultValue": []
    },
    {
      "name": "Tag",
      "type": "multiSelect",
      "options": [
        "Adapted to Anime", "Adapted to Manga", "Beautiful Female Lead",
        "Calm Protagonist", "Clever Protagonist", "Early Romance",
        "Evolution", "Game Elements", "Handsome Male Lead",
        "Cold Protagonist", "Male Protagonist", "Female Protagonist",
        "Overpowered Protagonist", "Weak to Strong",
        "Transmigration", "Reincarnation", "System", "Cultivation",
        "Virtual Reality", "Dungeon", "Regression",
        "Kingdom Building", "Academy", "Time Travel"
      ],
      "values": [
        "adapted-to-anime", "adapted-to-manga", "beautiful-female-lead",
        "calm-protagonist", "clever-protagonist", "early-romance",
        "evolution", "game-elements", "handsome-male-lead",
        "cold-protagonist", "male-protagonist", "female-protagonist",
        "overpowered-protagonist", "weak-to-strong",
        "transmigration", "reincarnation", "system", "cultivation",
        "virtual-reality", "dungeon", "regression",
        "kingdom-building", "academy", "time-travel"
      ],
      "defaultValue": []
    }
  ],
  "endpoints": {
    "search": {
      "path": "/search",
      "isApi": false,
      "params": {
        "keyword": "{query}",
        "page": "{page}"
      },
      "selector": {
        "list": "#list-page .row",
        "id": "h3 a@href | regex:/\\/b\\/([^\\/]+)/",
        "title": "h3 a@title",
        "coverUrl": "img@src",
        "author": ".author"
      },
      "nextPageSelector": ".pagination li.active + li a"
    },
    "popular": {
      "path": "/sort/{Sort}",
      "isApi": false,
      "pathOverrides": {
        "Genre": "/genre/{Genre}",
        "Tag": "/tag/{Tag}"
      },
      "params": {
        "page": "{page}"
      },
      "selector": {
        "list": "#list-page .row",
        "id": "h3 a@href | regex:/\\/b\\/([^\\/]+)/",
        "title": "h3 a@title",
        "coverUrl": "img@src",
        "author": ".author"
      },
      "nextPageSelector": ".pagination li.active + li a"
    },
    "latest": {
      "path": "/sort/latest",
      "isApi": false,
      "params": {
        "page": "{page}"
      },
      "selector": {
        "list": "#list-page .row",
        "id": "h3 a@href | regex:/\\/b\\/([^\\/]+)/",
        "title": "h3 a@title",
        "coverUrl": "img@src",
        "author": ".author"
      },
      "nextPageSelector": ".pagination li.active + li a"
    },
    "details": {
      "path": "/b/{seriesId}",
      "isApi": false,
      "selector": {
        "title": "h3.title",
        "coverUrl": ".book img@data-src",
        "author": ".info a[href*='/a/']",
        "description": ".desc-text",
        "status": ".info .text-primary",
        "tags": ".info a[href*='/genre/'], .info a[href*='/tag/']"
      }
    },
    "chapters": {
      "path": "/ajax/chapter-archive",
      "isApi": false,
      "useWebView": false,
      "params": {
        "novelId": "{seriesId}"
      },
      "selector": {
        "list": ".panel-body a[href*='/b/']",
        "id": "@href | regex:/([^\\/]+)\\/?$/",
        "title": "@title"
      }
    },
    "content": {
      "path": "/b/{seriesId}/{chapterSlug}",
      "isApi": false,
      "selector": {
        "title": "h2 a.chr-title@title",
        "content": "#chr-content"
      },
      "contentRemoveSelectors": [
        "div",
        "script",
        "span#span",
        ".adsbox",
        ".ad-container"
      ]
    }
  }
}
