{
  "id": "novelbin",
  "name": "NovelBin",
  "version": 15,
  "lang": "en",
  "baseUrl": "https://novelbin.com",
  "contentType": "text",
  "isApi": false,
  "supportsLatest": true,
  "useWebView": true,
  "rateLimit": {
    "requests": 1,
    "perSeconds": 1
  },
  "headers": {
    "Referer": "https://novelbin.com/"
  },
  "filters": [
    {
      "name": "Sort",
      "type": "select",
      "options": ["Popular", "Latest", "Completed", "Ongoing"],
      "values": ["top-view-novel", "latest", "completed", "ongoing"],
      "defaultValue": "top-view-novel"
    },
    {
      "name": "Genre",
      "type": "select",
      "options": [
        "All",
        "Action", "Adventure", "Anime & comics", "Comedy", "Drama",
        "Eastern", "Fan-fiction", "Fantasy", "Game", "Gender bender",
        "Harem", "Historical", "Horror", "Isekai", "Josei",
        "Litrpg", "Magic", "Magical realism", "Martial arts", "Mature",
        "Mecha", "Military", "Modern life", "Mystery", "Other",
        "Psychological", "Reincarnation", "Romance", "Romancei", "School life",
        "Sci-fi", "Seinen", "Shoujo", "Shoujo ai", "Shounen",
        "Shounen ai", "Slice of life", "Smut", "Sports", "Supernatural",
        "System", "Thriller", "Tragedy", "Urban", "Video games",
        "War", "Wuxia", "Xianxia", "Xuanhuan", "Yaoi", "Yuri"
      ],
      "values": [
        "",
        "action", "adventure", "anime-comics", "comedy", "drama",
        "eastern", "fan-fiction", "fantasy", "game", "gender-bender",
        "harem", "historical", "horror", "isekai", "josei",
