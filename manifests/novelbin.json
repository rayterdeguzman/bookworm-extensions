        "Dark", "Demons", "Dense Protagonist", "Devoted Love Interests",
        "Dragons", "Dungeon", "Dwarfs", "Early Romance",
        "Elves", "Evolution", "Farming",
        "Female Protagonist", "First Love", "Game Elements",
        "Genius Protagonist", "Ghosts", "Gore",
        "Guilds", "Handsome Male Lead", "Hard-Working Protagonist",
        "Hiding True Ability", "Kingdom Building", "Loner Protagonist",
        "Love Interest Falls First", "Magic", "Male Protagonist",
        "Monsters", "Multiple Protagonists", "Necromancer",
        "Nobles", "Orphan", "Overpowered Protagonist",
        "Parallel Worlds", "Pets", "Politics",
        "Post-Apocalyptic", "Protagonist Strong From the Start",
        "Regression", "Reincarnation", "Revenge",
        "Reverse Harem", "Royalty", "Ruthless Protagonist",
        "Second Chance", "Secret Identity", "Shapeshifters",
        "Slow Romance", "Summoner", "Sword And Magic",
        "System", "Time Travel", "Transmigration",
        "Underestimated Protagonist", "Unique Cultivation Technique",
        "Vampires", "Virtual Reality", "Wars",
        "Weak to Strong", "Zombies"
      ],
      "values": [
        "",
        "ACADEMY", "ADAPTED%20TO%20ANIME", "ADAPTED%20TO%20DRAMA", "ADAPTED%20TO%20MANGA",
        "ALCHEMY", "ALTERNATE%20WORLD", "ANTI-HERO",
        "ARTIFACTS", "BEAST%20COMPANIONS", "BEAUTIFUL%20FEMALE%20LEAD",
        "BETRAYAL", "BUSINESS%20MANAGEMENT", "CALM%20PROTAGONIST",
        "CAUTIOUS%20PROTAGONIST", "CLEVER%20PROTAGONIST", "COLD%20PROTAGONIST",
        "COMING%20OF%20AGE", "COOKING", "CRAFTING", "CULTIVATION",
        "DARK", "DEMONS", "DENSE%20PROTAGONIST", "DEVOTED%20LOVE%20INTERESTS",
        "DRAGONS", "DUNGEON", "DWARFS", "EARLY%20ROMANCE",
        "ELVES", "EVOLUTION", "FARMING",
        "FEMALE%20PROTAGONIST", "FIRST%20LOVE", "GAME%20ELEMENTS",
        "GENIUS%20PROTAGONIST", "GHOSTS", "GORE",
        "GUILDS", "HANDSOME%20MALE%20LEAD", "HARD-WORKING%20PROTAGONIST",
        "HIDING%20TRUE%20ABILITY", "KINGDOM%20BUILDING", "LONER%20PROTAGONIST",
        "LOVE%20INTEREST%20FALLS%20FIRST", "MAGIC", "MALE%20PROTAGONIST",
        "MONSTERS", "MULTIPLE%20PROTAGONISTS", "NECROMANCER",
        "NOBLES", "ORPHAN", "OVERPOWERED%20PROTAGONIST",
        "PARALLEL%20WORLDS", "PETS", "POLITICS",
        "POST-APOCALYPTIC", "PROTAGONIST%20STRONG%20FROM%20THE%20START",
        "REGRESSION", "REINCARNATION", "REVENGE",
        "REVERSE%20HAREM", "ROYALTY", "RUTHLESS%20PROTAGONIST",
        "SECOND%20CHANCE", "SECRET%20IDENTITY", "SHAPESHIFTERS",
        "SLOW%20ROMANCE", "SUMMONER", "SWORD%20AND%20MAGIC",
        "SYSTEM", "TIME%20TRAVEL", "TRANSMIGRATION",
        "UNDERESTIMATED%20PROTAGONIST", "UNIQUE%20CULTIVATION%20TECHNIQUE",
        "VAMPIRES", "VIRTUAL%20REALITY", "WARS",
        "WEAK%20TO%20STRONG", "ZOMBIES"
      ],
      "defaultValue": ""
    }
  ],
  "endpoints": {
    "search": {
      "path": "/search",
      "isApi": false,
      "pathOverrides": {
        "Genre": "/genre/{Genre}",
        "Tag": "/tag/{Tag}",
        "Sort": "/sort/{Sort}"
      },
      "params": {
        "keyword": "{query}",
        "page": "{page}"
      },
      "selector": {
        "list": "#list-page .row",
        "id": "h3 a@href | regex:/\\/b\\/([^\\/]+)/",
        "title": "h3 a@title",
        "coverUrl": "img@src",
        "author": ".author"
      },
      "nextPageSelector": ".pagination li.active + li a"
    },
    "popular": {
      "path": "/sort/{Sort}",
      "isApi": false,
      "pathOverrides": {
        "Genre": "/genre/{Genre}",
        "Tag": "/tag/{Tag}"
      },
      "params": {
        "page": "{page}"
      },
      "selector": {
        "list": "#list-page .row",
        "id": "h3 a@href | regex:/\\/b\\/([^\\/]+)/",
        "title": "h3 a@title",
        "coverUrl": "img@src",
        "author": ".author"
      },
      "nextPageSelector": ".pagination li.active + li a"
    },
    "latest": {
      "path": "/sort/latest",
      "isApi": false,
      "params": {
        "page": "{page}"
      },
      "selector": {
        "list": "#list-page .row",
        "id": "h3 a@href | regex:/\\/b\\/([^\\/]+)/",
        "title": "h3 a@title",
        "coverUrl": "img@src",
        "author": ".author"
      },
      "nextPageSelector": ".pagination li.active + li a"
    },
    "details": {
      "path": "/b/{seriesId}",
      "isApi": false,
      "selector": {
        "title": "h3.title",
        "coverUrl": ".book img@data-src",
        "author": ".info a[href*='/a/']",
        "description": ".desc-text",
        "status": ".info .text-primary",
        "tags": ".info a[href*='/genre/'], .info a[href*='/tag/']"
      }
    },
    "chapters": {
      "path": "/ajax/chapter-archive",
      "isApi": false,
      "useWebView": false,
      "params": {
        "novelId": "{seriesId}"
      },
      "selector": {
        "list": ".panel-body a[href*='/b/']",
        "id": "@href | regex:/([^\\/]+)\\/?$/",
        "title": "@title"
      }
    },
    "content": {
      "path": "/b/{seriesId}/{chapterSlug}",
      "isApi": false,
      "selector": {
        "title": "h2 a.chr-title@title",
        "content": "#chr-content"
      },
      "contentRemoveSelectors": [
        "div",
        "script",
        "span#span",
        ".adsbox",
        ".ad-container"
      ]
    }
  }
}
