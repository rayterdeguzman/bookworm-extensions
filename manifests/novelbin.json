        "mecha", "military", "modern-life", "mystery", "other",
        "psychological", "reincarnation", "romance", "romancei", "school-life",
        "sci-fi", "seinen", "shoujo", "shoujo-ai", "shounen",
        "shounen-ai", "slice-of-life", "smut", "sports", "supernatural",
        "system", "thriller", "tragedy", "urban", "video-games",
        "war", "wuxia", "xianxia", "xuanhuan", "yaoi", "yuri"
      ],
      "defaultValue": ""
    },
    {
      "name": "Tag",
      "type": "select",
      "options": [
        "All",
        "Academy", "Adapted to Anime", "Adapted to Drama", "Adapted to Manga",
        "Alchemy", "Alternate World", "Anti-hero",
        "Artifacts", "Beast Companions", "Beautiful Female Lead",
        "Betrayal", "Business Management", "Calm Protagonist",
        "Cautious Protagonist", "Clever Protagonist", "Cold Protagonist",
