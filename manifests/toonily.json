{
  "id": "toonily",
  "name": "Toonily",
  "version": 5,
  "lang": "en",
  "baseUrl": "https://toonily.me",
  "contentType": "image",
  "supportsLatest": true,
  "useWebView": true,
  "rateLimit": {
    "requests": 1,
    "perSeconds": 1
  },
  "headers": {
    "Referer": "https://toonily.me/"
  },
  "filters": [
    {
      "name": "Order",
      "type": "select",
      "options": ["Views", "Updated", "Created", "Name A-Z", "Rating"],
      "values": ["views", "updated_at", "created_at", "name", "rating"],
      "defaultValue": "views"
    },
    {
      "name": "Status",
      "type": "select",
      "options": ["All", "Ongoing", "Completed"],
      "values": ["all", "ongoing", "completed"],
      "defaultValue": "all"
    },
    {
      "name": "Genre",
      "type": "multiSelect",
      "options": [
        "Action", "Adult", "Adventure", "Comedy", "Drama", "Ecchi",
        "Fantasy", "Gender Bender", "Harem", "Historical", "Horror",
        "Josei", "Martial Arts", "Mature", "Mecha", "Mystery",
        "Psychological", "Romance", "School Life", "Sci-fi", "Seinen",
        "Shoujo", "Shounen", "Slice of Life", "Smut", "Sports",
        "Supernatural", "Tragedy", "Yaoi", "Yuri"
      ],
      "values": [
        "action", "adult", "adventure", "comedy", "drama", "ecchi",
        "fantasy", "gender-bender", "harem", "historical", "horror",
        "josei", "martial-arts", "mature", "mecha", "mystery",
        "psychological", "romance", "school-life", "sci-fi", "seinen",
        "shoujo", "shounen", "slice-of-life", "smut", "sports",
        "supernatural", "tragedy", "yaoi", "yuri"
      ],
      "defaultValue": []
    }
  ],
  "endpoints": {
    "search": {
      "path": "/search",
      "isApi": false,
      "params": {
        "q": "{query}",
        "sort": "{Order}",
        "status": "{Status}",
        "genre[]": "{Genre}",
        "page": "{page}"
      },
      "waitForSelector": ".book-detailed-item",
      "selector": {
        "list": ".book-detailed-item",
        "id": ".meta .title h3 a@href | regex:/\\/([^\\/]+)\\/?$/",
        "title": ".meta .title h3 a",
        "coverUrl": ".thumb img@data-src"
      },
      "nextPageSelector": ".paginator > a.active + a:not([rel=next])"
    },
    "popular": {
      "path": "/search",
      "isApi": false,
      "params": {
        "sort": "views",
        "page": "{page}"
      },
      "waitForSelector": ".book-detailed-item",
      "selector": {
        "list": ".book-detailed-item",
        "id": ".meta .title h3 a@href | regex:/\\/([^\\/]+)\\/?$/",
        "title": ".meta .title h3 a",
        "coverUrl": ".thumb img@data-src"
      },
      "nextPageSelector": ".paginator > a.active + a:not([rel=next])"
    },
    "latest": {
      "path": "/search",
      "isApi": false,
      "params": {
        "sort": "updated_at",
        "page": "{page}"
      },
      "waitForSelector": ".book-detailed-item",
      "selector": {
        "list": ".book-detailed-item",
        "id": ".meta .title h3 a@href | regex:/\\/([^\\/]+)\\/?$/",
        "title": ".meta .title h3 a",
        "coverUrl": ".thumb img@data-src"
      },
      "nextPageSelector": ".paginator > a.active + a:not([rel=next])"
    },
    "details": {
      "path": "/{seriesId}",
      "isApi": false,
      "waitForSelector": ".detail h1",
      "selector": {
        "title": ".detail h1",
        "coverUrl": "#cover img@data-src",
        "description": ".summary .content",
        "author": ".detail .meta > p:nth-child(1) a",
        "status": ".detail .meta > p:nth-child(2) a",
        "tags": ".detail .meta > p:nth-child(3) a"
      }
    },
    "chapters": {
      "path": "/{seriesId}/chapters",
      "isApi": false,
      "params": {
        "source": "detail"
      },
      "selector": {
        "list": "li",
        "id": "a@href | regex:/\\/[^\\/]+\\/([^\\/]+)\\/?$/",
        "title": "strong"
      }
    },
    "pages": {
      "path": "/{seriesId}/{chapterSlug}",
      "isApi": false,
      "waitForSelector": ".chapter-image img",
      "selector": {
        "pages": ".chapter-image img, #chapter-images img",
        "src": "data-src",
        "title": "h1#chapter-heading"
      }
    }
  }
}
