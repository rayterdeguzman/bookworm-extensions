{
  "id": "toonily",
  "name": "Toonily",
  "version": 10,
  "lang": "en",
  "baseUrl": "https://toonily.com",
  "contentType": "image",
  "supportsLatest": true,
  "useWebView": true,
  "rateLimit": {
    "requests": 1,
    "perSeconds": 1
  },
  "headers": {
    "Referer": "https://toonily.com/"
  },
  "cookies": {
    "toonily-mature": "{Show Adult}"
  },
  "filters": [
    {
      "name": "Show Adult",
      "type": "checkbox",
      "defaultValue": "0"
    },
    {
      "name": "Order",
      "type": "select",
      "options": ["Trending", "Most Views", "New", "Latest", "A-Z", "Rating"],
      "values": ["trending", "views", "new-manga", "latest", "alphabet", "rating"],
      "defaultValue": "trending"
    },
    {
      "name": "Status",
      "type": "select",
      "options": ["All", "Ongoing", "Completed", "On Hold", "Canceled"],
      "values": ["", "on-going", "end", "on-hold", "canceled"],
      "defaultValue": ""
    },
    {
      "name": "Genre",
      "type": "multiSelect",
      "options": [
        "Action", "Adult", "Adventure", "BL", "Comedy", "Drama", "Ecchi",
        "Fantasy", "GL", "Harem", "Historical", "Horror", "Josei",
        "Martial Arts", "Mature", "Mystery", "Psychological", "Romance",
        "School Life", "Sci-fi", "Seinen", "Shoujo", "Shounen",
        "Slice of Life", "Smut", "Sports", "Supernatural", "Thriller",
        "Tragedy", "Yaoi", "Yuri"
      ],
      "values": [
        "action", "adult", "adventure", "bl", "comedy", "drama", "ecchi",
        "fantasy", "gl", "harem", "historical", "horror", "josei",
        "martial-arts", "mature", "mystery", "psychological", "romance",
        "school-life", "sci-fi", "seinen", "shoujo", "shounen",
        "slice-of-life", "smut", "sports", "supernatural", "thriller",
        "tragedy", "yaoi", "yuri"
      ],
      "defaultValue": []
    }
  ],
  "endpoints": {
    "search": {
      "path": "/serie/",
      "isApi": false,
      "params": {
        "s": "{query}",
        "post_type": "wp-manga",
        "paged": "{page}",
        "m_orderby": "{Order}",
        "status[]": "{Status}",
        "genre[]": "{Genre}"
      },
      "waitForSelector": "div.page-item-detail, div.c-tabs-item__content, div.not-found",
      "selector": {
        "list": "div.page-item-detail, div.c-tabs-item__content",
        "id": ".post-title a@href | regex:/\\/serie\\/([^\\/]+)/",
        "title": ".post-title a",
        "coverUrl": ".item-thumb img@data-src, .tab-thumb img@data-src"
      },
      "nextPageSelector": "div.nav-previous a, a.nextpostslink, a.next.page-numbers"
    },
    "popular": {
      "path": "/serie/",
      "isApi": false,
      "params": {
        "m_orderby": "views",
        "paged": "{page}",
        "status[]": "{Status}",
        "genre[]": "{Genre}"
      },
      "waitForSelector": "div.page-item-detail, div.not-found",
      "selector": {
        "list": "div.page-item-detail",
        "id": ".post-title a@href | regex:/\\/serie\\/([^\\/]+)/",
        "title": ".post-title a",
        "coverUrl": ".item-thumb img@data-src"
      },
      "nextPageSelector": "div.nav-previous a, a.nextpostslink, a.next.page-numbers"
    },
    "latest": {
      "path": "/serie/",
      "isApi": false,
      "params": {
        "m_orderby": "latest",
        "paged": "{page}",
        "status[]": "{Status}",
        "genre[]": "{Genre}"
      },
      "waitForSelector": "div.page-item-detail, div.not-found",
      "selector": {
        "list": "div.page-item-detail",
        "id": ".post-title a@href | regex:/\\/serie\\/([^\\/]+)/",
        "title": ".post-title a",
        "coverUrl": ".item-thumb img@data-src"
      },
      "nextPageSelector": "div.nav-previous a, a.nextpostslink, a.next.page-numbers"
    },
    "details": {
      "path": "/serie/{seriesId}/",
      "isApi": false,
      "waitForSelector": "div.post-title h1, div.summary_image",
      "extractVars": {
        "postId": "[id^='manga-chapters-holder']@data-id"
      },
      "selector": {
        "title": "div.post-title h1",
        "coverUrl": "div.summary_image img@data-src",
        "description": "div.description-summary div.summary__content@html",
        "author": "div.author-content > a",
        "status": "div.post-status .post-content_item:last-child .summary-content",
        "tags": "div.genres-content a"
      }
    },
    "chapters": {
      "path": "/serie/{seriesId}/ajax/chapters/",
      "method": "POST",
      "isApi": false,
      "useWebView": false,
      "selector": {
        "list": "li.wp-manga-chapter",
        "id": "a@href | regex:/\\/serie\\/[^\\/]+\\/([^\\/]+)\\/?$/",
        "title": "a",
        "dateUploaded": "span.chapter-release-date"
      }
    },
    "pages": {
      "path": "/serie/{seriesId}/{chapterSlug}/",
      "isApi": false,
      "waitForSelector": "div.page-break img, .reading-content img",
      "selector": {
        "pages": "div.page-break img, .reading-content img.wp-manga-chapter-img",
        "src": "data-src",
        "title": "h1#chapter-heading"
      }
    }
  }
}
