{
  "id": "freewebnovel",
  "name": "FreeWebNovel",
  "version": 5,
  "lang": "en",
  "baseUrl": "https://freewebnovel.com",
  "contentType": "text",
  "isApi": false,
  "supportsLatest": true,
  "useWebView": false,
  "rateLimit": {
    "requests": 1,
    "perSeconds": 1
  },
  "headers": {
    "Referer": "https://freewebnovel.com/"
  },
  "filters": [
    {
      "name": "Sort",
      "type": "select",
      "options": ["Latest Release", "Latest Novels", "Completed"],
      "values": ["latest-release", "latest-novel", "completed-novel"],
      "defaultValue": "latest-release"
    },
    {
      "name": "Genre",
      "type": "select",
      "options": [
        "All",
        "Action", "Adult", "Adventure", "Comedy", "Drama",
        "Eastern", "Ecchi", "Fantasy", "Game", "Gender Bender",
        "Harem", "Historical", "Horror", "Josei",
        "Martial Arts", "Mature", "Mecha", "Mystery",
        "Psychological", "Reincarnation", "Romance", "School Life",
        "Sci-fi", "Seinen", "Shoujo", "Shounen", "Shounen Ai",
        "Slice of Life", "Smut", "Sports", "Supernatural",
        "Tragedy", "Wuxia", "Xianxia", "Xuanhuan", "Yaoi"
      ],
      "values": [
        "",
        "Action", "Adult", "Adventure", "Comedy", "Drama",
        "Eastern", "Ecchi", "Fantasy", "Game", "Gender+Bender",
        "Harem", "Historical", "Horror", "Josei",
        "Martial+Arts", "Mature", "Mecha", "Mystery",
        "Psychological", "Reincarnation", "Romance", "School+Life",
        "Sci-fi", "Seinen", "Shoujo", "Shounen", "Shounen+Ai",
        "Slice+of+Life", "Smut", "Sports", "Supernatural",
        "Tragedy", "Wuxia", "Xianxia", "Xuanhuan", "Yaoi"
      ],
      "defaultValue": ""
    }
  ],
  "endpoints": {
    "search": {
      "path": "/search/",
      "isApi": false,
      "pathOverrides": {
        "Genre": "/genre/{Genre}/{page}",
        "Sort": "/sort/{Sort}/{page}"
      },
      "params": {
        "searchkey": "{query}"
      },
      "selector": {
        "list": "div.li-row",
        "id": "h3.tit a@href | regex:/\\/novel\\/([^\\/]+)/",
        "title": "h3.tit a@title",
        "coverUrl": "div.pic img@data-src"
      }
    },
    "popular": {
      "path": "/sort/{Sort}/{page}",
      "isApi": false,
      "pathOverrides": {
        "Genre": "/genre/{Genre}/{page}"
      },
      "selector": {
        "list": "div.li-row",
        "id": "h3.tit a@href | regex:/\\/novel\\/([^\\/]+)/",
        "title": "h3.tit a@title",
        "coverUrl": "div.pic img@data-src"
      }
    },
    "latest": {
      "path": "/sort/latest-novel/{page}",
      "isApi": false,
      "selector": {
        "list": "div.li-row",
        "id": "h3.tit a@href | regex:/\\/novel\\/([^\\/]+)/",
        "title": "h3.tit a@title",
        "coverUrl": "div.pic img@data-src"
      }
    },
    "details": {
      "path": "/novel/{seriesId}",
      "isApi": false,
      "selector": {
        "title": "div.m-desc h1.tit",
        "coverUrl": ".m-imgtxt img@data-src",
        "author": ".m-imgtxt a[href*='/author/']",
        "description": "div.m-desc div.txt",
        "status": "a[href*='/sort/completed'], a[href*='/sort/ongoing']",
        "tags": "a[href*='/genre/']"
      }
    },
    "chapters": {
      "path": "/novel/{seriesId}",
      "isApi": false,
      "selector": {
        "list": "#idData li",
        "id": "a@href | regex:/([^\\/]+)\\/?$/",
        "title": "a@title"
      }
    },
    "content": {
      "path": "/novel/{seriesId}/{chapterSlug}",
      "isApi": false,
      "selector": {
        "title": "span.chapter",
        "content": "div.m-read .txt"
      },
      "contentRemoveSelectors": [
        "script",
        "style",
        "h4",
        "sub",
        ".notice-text",
        ".adsbox",
        ".ad-container",
        ".bg"
      ]
    }
  }
}
