  {
    "id": "ravenscans",
    "name": "Raven Scans (Yaksha)",
    "version": 2,
    "lang": "en",
    "baseUrl": "https://ravenscans.org",
    "contentType": "image",
    "isApi": true,
    "supportsLatest": true,
    "useWebView": false,
    "rateLimit": {
      "requests": 3,
      "perSeconds": 1
    },
    "headers": {
      "Referer": "https://ravenscans.org/"
    },
    "endpoints": {
      "search": {
        "path": "/wp-json/wp/v2/categories",
        "params": {
          "search": "{query}",
          "per_page": "20",
          "page": "{page}"
        },
        "mapping": {
          "list": "$.data",
          "id": "$.id",
          "title": "$.name"
        },
        "nextPagePath": "$.data"
      },
      "popular": {
        "path": "/wp-json/wp/v2/categories",
        "params": {
          "orderby": "count",
          "order": "desc",
          "per_page": "20",
          "page": "{page}"
        },
        "mapping": {
          "list": "$.data",
          "id": "$.id",
          "title": "$.name"
        },
        "nextPagePath": "$.data"
      },
      "latest": {
        "path": "/wp-json/wp/v2/categories",
        "params": {
          "orderby": "count",
          "order": "desc",
          "per_page": "20",
          "page": "{page}"
        },
        "mapping": {
          "list": "$.data",
          "id": "$.id",
          "title": "$.name"
        },
        "nextPagePath": "$.data"
      },
      "details": {
        "path": "/wp-json/wp/v2/categories/{seriesId}",
        "mapping": {
          "id": "$.id",
          "title": "$.name",
          "description": "$.description"
        }
      },
      "chapters": {
        "path": "/wp-json/wp/v2/posts",
        "params": {
          "categories": "{seriesId}",
          "per_page": "100",
          "orderby": "date",
          "order": "asc",
          "_fields": "id,title,date,content"
        },
        "mapping": {
          "list": "$.data",
          "id": "$.id",
          "title": "$.title.rendered",
          "dateUploaded": "$.date"
        }
      },
      "pages": {
        "path": "/wp-json/wp/v2/posts/{chapterSlug}",
        "params": {
          "_fields": "id,title,content"
        },
        "mapping": {
          "htmlField": "$.content.rendered",
          "htmlSelector": "img@src",
          "title": "$.title.rendered"
        }
      }
    }
  }
