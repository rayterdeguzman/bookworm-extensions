{
  "id": "ravenscans",
  "name": "Raven Scans (Yaksha)",
  "version": 19,
  "lang": "en",
  "baseUrl": "https://ravenscans.me",
  "contentType": "image",
  "isApi": false,
  "supportsLatest": true,
  "useWebView": true,
  "rateLimit": {
    "requests": 3,
    "perSeconds": 1
  },
  "headers": {
    "Referer": "https://ravenscans.me/"
  },
  "filters": [
    {
      "name": "Order",
      "type": "select",
      "options": ["Trending", "Latest", "New", "A-Z", "Rating"],
      "values": ["trending", "latest", "new-manga", "alphabet", "rating"],
      "defaultValue": "trending"
    },
    {
      "name": "Status",
      "type": "select",
      "options": ["All", "Ongoing", "Completed", "Hiatus"],
      "values": ["", "ongoing", "completed", "hiatus"],
      "defaultValue": ""
    },
    {
      "name": "Type",
      "type": "select",
      "options": ["All", "Manga", "Manhwa", "Manhua", "Comic", "Novel"],
      "values": ["", "manga", "manhwa", "manhua", "comic", "novel"],
      "defaultValue": ""
    },
    {
      "name": "Genre",
      "type": "multiSelect",
      "options": [
        "Action", "Adult", "Adventure", "Comedy", "Drama", "Ecchi",
        "Fantasy", "Gender Bender", "Harem", "Historical", "Horror",
        "Josei", "Martial Arts", "Mature", "Mecha", "Mystery",
        "Psychological", "Romance", "School Life", "Sci-fi", "Seinen",
        "Shoujo", "Shoujo Ai", "Shounen", "Shounen Ai", "Slice of Life",
        "Smut", "Sports", "Supernatural", "Tragedy", "Yaoi", "Yuri"
      ],
      "values": [
        "action", "adult", "adventure", "comedy", "drama", "ecchi",
        "fantasy", "gender-bender", "harem", "historical", "horror",
        "josei", "martial-arts", "mature", "mecha", "mystery",
        "psychological", "romance", "school-life", "sci-fi", "seinen",
        "shoujo", "shoujo-ai", "shounen", "shounen-ai", "slice-of-life",
        "smut", "sports", "supernatural", "tragedy", "yaoi", "yuri"
      ],
      "defaultValue": []
    }
  ],
  "endpoints": {
    "search": {
      "path": "/series/",
      "isApi": false,
      "params": {
        "s": "{query}",
        "paged": "{page}"
      },
      "selector": {
        "list": "div.bsx",
        "id": "a@href | regex:/\\/series\\/([^\\/]+)/",
        "title": ".tt",
        "coverUrl": ".limit img@src"
      },
      "nextPageSelector": "a.next.page-numbers"
    },
    "popular": {
      "path": "/wp-admin/admin-ajax.php",
      "method": "POST",
      "isApi": false,
      "useWebView": false,
      "allowEmptyParams": true,
      "params": {
        "action": "madara_load_more",
        "page": "{(page-1)}",
        "template": "madara-core/content/content-archive",
        "vars[orderby]": "{Order}",
        "vars[sidebar]": "full",
        "vars[paged]": "1",
        "vars[meta_key]": "",
        "vars[order]": "DESC"
      },
      "selector": {
        "list": ".page-item-detail",
        "id": "a@href | regex:/\\/series\\/([^\\/]+)/",
        "title": ".post-title a",
        "coverUrl": "img@src"
      }
    },
    "latest": {
      "path": "/wp-admin/admin-ajax.php",
      "method": "POST",
      "isApi": false,
      "useWebView": false,
      "allowEmptyParams": true,
      "params": {
        "action": "madara_load_more",
        "page": "{(page-1)}",
        "template": "madara-core/content/content-archive",
        "vars[orderby]": "latest",
        "vars[sidebar]": "full",
        "vars[paged]": "1",
        "vars[meta_key]": "",
        "vars[order]": "DESC"
      },
      "selector": {
        "list": ".page-item-detail",
        "id": "a@href | regex:/\\/series\\/([^\\/]+)/",
        "title": ".post-title a",
        "coverUrl": "img@src"
      }
    },
    "details": {
      "path": "/series/{seriesId}/",
      "isApi": false,
      "useWebView": false,
      "selector": {
        "title": "h1.entry-title",
        "coverUrl": "div.thumb img@src",
        "description": "div.entry-content.entry-content-single",
        "status": ".tsinfo .imptdt:first-child i",
        "tags": ".mgen a"
      }
    },
    "chapters": {
      "path": "/series/{seriesId}/",
      "isApi": false,
      "useWebView": false,
      "selector": {
        "list": "#chapterlist ul li",
        "id": ".eph-num a@href | regex:/([^\\/]+)\\/?$/",
        "title": ".chapternum",
        "dateUploaded": ".chapterdate"
      }
    },
    "pages": {
      "path": "/{chapterSlug}/",
      "isApi": false,
      "selector": {
        "pages": "#readerarea img",
        "src": "src",
        "title": "h1.entry-title"
      }
    }
  }
}
