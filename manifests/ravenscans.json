{
  "id": "ravenscans",
  "name": "Raven Scans (Yaksha)",
  "version": 7,
  "lang": "en",
  "baseUrl": "https://ravenscans.org",
  "contentType": "image",
  "isApi": true,
  "supportsLatest": true,
  "useWebView": true,
  "rateLimit": {
    "requests": 3,
    "perSeconds": 1
  },
  "headers": {
    "Referer": "https://ravenscans.org/"
  },
  "filters": [
    {
      "name": "Order",
      "type": "select",
      "options": ["Popular", "Latest Update", "Latest Added", "A-Z", "Z-A"],
      "values": ["popular", "update", "latest", "title", "titlereverse"],
      "defaultValue": "popular"
    },
    {
      "name": "Status",
      "type": "select",
      "options": ["All", "Ongoing", "Completed", "Hiatus"],
      "values": ["", "ongoing", "completed", "hiatus"],
      "defaultValue": ""
    },
    {
      "name": "Type",
      "type": "select",
      "options": ["All", "Manga", "Manhwa", "Manhua", "Comic", "Novel"],
      "values": ["", "manga", "manhwa", "manhua", "comic", "novel"],
      "defaultValue": ""
    },
    {
      "name": "Genre",
      "type": "multiSelect",
      "options": [
        "Action", "Adult", "Adventure", "Comedy", "Drama", "Ecchi",
        "Fantasy", "Gender Bender", "Harem", "Historical", "Horror",
        "Josei", "Martial Arts", "Mature", "Mecha", "Mystery",
        "Psychological", "Romance", "School Life", "Sci-fi", "Seinen",
        "Shoujo", "Shoujo Ai", "Shounen", "Shounen Ai", "Slice of Life",
        "Smut", "Sports", "Supernatural", "Tragedy", "Yaoi", "Yuri"
      ],
      "values": [
        "4", "43", "27", "5", "12", "13",
        "6", "51", "14", "7", "33",
        "44", "8", "45", "59", "46",
        "47", "9", "28", "40", "49",
        "50", "52", "10", "53", "54",
        "48", "55", "24", "56", "57", "58"
      ],
      "defaultValue": []
    }
  ],
  "endpoints": {
    "search": {
      "path": "/manga/",
      "isApi": false,
      "params": {
        "s": "{query}",
        "page": "{page}",
        "order": "{Order}",
        "status": "{Status}",
        "type": "{Type}",
        "genre[]": "{Genre}"
      },
      "selector": {
        "list": "div.bsx",
        "id": "a@href | regex:/\\/manga\\/([^\\/]+)/",
        "title": ".tt",
        "coverUrl": ".limit img@src"
      },
      "nextPageSelector": "a.next.page-numbers"
    },
    "popular": {
      "path": "/manga/",
      "isApi": false,
      "params": {
        "order": "popular",
        "page": "{page}"
      },
      "selector": {
        "list": "div.bsx",
        "id": "a@href | regex:/\\/manga\\/([^\\/]+)/",
        "title": ".tt",
        "coverUrl": ".limit img@src"
      },
      "nextPageSelector": "a.next.page-numbers"
    },
    "latest": {
      "path": "/manga/",
      "isApi": false,
      "params": {
        "order": "update",
        "page": "{page}"
      },
      "selector": {
        "list": "div.bsx",
        "id": "a@href | regex:/\\/manga\\/([^\\/]+)/",
        "title": ".tt",
        "coverUrl": ".limit img@src"
      },
      "nextPageSelector": "a.next.page-numbers"
    },
    "details": {
      "path": "/manga/{seriesId}/",
      "isApi": false,
      "selector": {
        "title": "h1.entry-title",
        "coverUrl": "div.thumb img@src",
        "description": "div.entry-content.entry-content-single",
        "status": ".tsinfo .imptdt:first-child i"
      }
    },
    "chapters": {
      "path": "/manga/{seriesId}/",
      "isApi": false,
      "selector": {
        "list": "#chapterlist ul li",
        "id": ".eph-num a@href | regex:/([^\\/]+)\\/?$/",
        "title": ".chapternum",
        "dateUploaded": ".chapterdate"
      }
    },
    "pages": {
      "path": "/{chapterSlug}/",
      "isApi": false,
      "selector": {
        "pages": "#readerarea img",
        "src": "src",
        "title": "h1.entry-title"
      }
    }
  }
}
