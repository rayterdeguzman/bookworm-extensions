{
  "id": "ravenscans",
  "name": "Raven Scans (Yaksha)",
  "version": 4,
  "lang": "en",
  "baseUrl": "https://ravenscans.org",
  "contentType": "image",
  "isApi": true,
  "supportsLatest": true,
  "useWebView": false,
  "rateLimit": {
    "requests": 3,
    "perSeconds": 1
  },
  "headers": {
    "Referer": "https://ravenscans.org/"
  },
  "endpoints": {
    "search": {
      "path": "/wp-json/wp/v2/categories",
      "params": {
        "search": "{query}",
        "per_page": "20",
        "page": "{page}"
      },
      "mapping": {
        "list": "$",
        "id": "$.slug",
        "title": "$.name"
      },
      "nextPagePath": "$"
    },
    "popular": {
      "path": "/wp-json/wp/v2/categories",
      "params": {
        "orderby": "count",
        "order": "desc",
        "per_page": "20",
        "page": "{page}"
      },
      "mapping": {
        "list": "$",
        "id": "$.slug",
        "title": "$.name"
      },
      "nextPagePath": "$"
    },
    "latest": {
      "path": "/wp-json/wp/v2/categories",
      "params": {
        "orderby": "count",
        "order": "desc",
        "per_page": "20",
        "page": "{page}"
      },
      "mapping": {
        "list": "$",
        "id": "$.slug",
        "title": "$.name"
      },
      "nextPagePath": "$"
    },
    "details": {
      "path": "/manga/{seriesId}/",
      "isApi": false,
      "selector": {
        "title": "h1.entry-title",
        "coverUrl": "div.thumb img@src",
        "description": "div.entry-content.entry-content-single",
        "status": ".tsinfo .imptdt:first-child i"
      }
    },
    "chapters": {
      "path": "/manga/{seriesId}/",
      "isApi": false,
      "selector": {
        "list": "#chapterlist ul li",
        "id": ".eph-num a@href | regex:/([^\\/]+)\\/?$/",
        "title": ".chapternum"
      }
    },
    "pages": {
      "path": "/{chapterSlug}/",
      "isApi": false,
      "selector": {
        "pages": "#readerarea img",
        "src": "src",
        "title": "h1.entry-title"
      }
    }
  }
}
