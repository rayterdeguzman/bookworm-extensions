{
  "id": "ravenscans",
  "name": "Raven Scans (Yaksha)",
  "version": 5,
  "lang": "en",
  "baseUrl": "https://ravenscans.org",
  "contentType": "image",
  "isApi": true,
  "supportsLatest": true,
  "useWebView": false,
  "rateLimit": {
    "requests": 3,
    "perSeconds": 1
  },
  "headers": {
    "Referer": "https://ravenscans.org/"
  },
  "filters": [
    {
      "name": "Order",
      "type": "select",
      "options": ["popular", "update", "latest", "title", "titlereverse"],
      "defaultValue": "popular"
    },
    {
      "name": "Status",
      "type": "select",
      "options": ["", "ongoing", "completed", "hiatus"],
      "defaultValue": ""
    },
    {
      "name": "Type",
      "type": "select",
      "options": ["", "manga", "manhwa", "manhua", "comic", "novel"],
      "defaultValue": ""
    }
  ],
  "endpoints": {
    "search": {
      "path": "/manga/",
      "isApi": false,
      "params": {
        "s": "{query}",
        "page": "{page}",
        "order": "{Order}",
        "status": "{Status}",
        "type": "{Type}"
      },
      "selector": {
        "list": "div.bsx",
        "id": "a@href | regex:/\\/manga\\/([^\\/]+)/",
        "title": ".tt",
        "coverUrl": ".limit img@src"
      },
      "nextPageSelector": "a.next.page-numbers"
    },
    "popular": {
      "path": "/manga/",
      "isApi": false,
      "params": {
        "order": "popular",
        "page": "{page}"
      },
      "selector": {
        "list": "div.bsx",
        "id": "a@href | regex:/\\/manga\\/([^\\/]+)/",
        "title": ".tt",
        "coverUrl": ".limit img@src"
      },
      "nextPageSelector": "a.next.page-numbers"
    },
    "latest": {
      "path": "/manga/",
      "isApi": false,
      "params": {
        "order": "update",
        "page": "{page}"
      },
      "selector": {
        "list": "div.bsx",
        "id": "a@href | regex:/\\/manga\\/([^\\/]+)/",
        "title": ".tt",
        "coverUrl": ".limit img@src"
      },
      "nextPageSelector": "a.next.page-numbers"
    },
    "details": {
      "path": "/manga/{seriesId}/",
      "isApi": false,
      "selector": {
        "title": "h1.entry-title",
        "coverUrl": "div.thumb img@src",
        "description": "div.entry-content.entry-content-single",
        "status": ".tsinfo .imptdt:first-child i"
      }
    },
    "chapters": {
      "path": "/manga/{seriesId}/",
      "isApi": false,
      "selector": {
        "list": "#chapterlist ul li",
        "id": ".eph-num a@href | regex:/([^\\/]+)\\/?$/",
        "title": ".chapternum"
      }
    },
    "pages": {
      "path": "/{chapterSlug}/",
      "isApi": false,
      "selector": {
        "pages": "#readerarea img",
        "src": "src",
        "title": "h1.entry-title"
      }
    }
  }
}
