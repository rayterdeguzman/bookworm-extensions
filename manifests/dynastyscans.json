{
  "id": "dynastyscans",
  "name": "Dynasty Scans",
  "version": 2,
  "lang": "en",
  "baseUrl": "https://dynasty-scans.com",
  "contentType": "image",
  "isApi": false,
  "supportsLatest": true,
  "useWebView": false,
  "rateLimit": {
    "requests": 3,
    "perSeconds": 1
  },
  "headers": {
    "Referer": "https://dynasty-scans.com/"
  },
  "filters": [
    {
      "name": "Sort",
      "type": "select",
      "options": ["Best Match", "Alphabetical", "Date Added", "Release Date"],
      "values": ["", "name", "created_at", "released_on"],
      "defaultValue": ""
    },
    {
      "name": "Tag",
      "type": "multiSelect",
      "options": [
        "4-koma",
        "Action",
        "Adventure",
        "Age gap",
        "Comedy",
        "College",
        "Couple life",
        "Drama",
        "Fantasy",
        "Full color",
        "Gender bender",
        "Het",
        "Historical",
        "Horror",
        "Idol",
        "Isekai",
        "Long strip",
        "Mahou shoujo",
        "Maid",
        "Medieval",
        "Mecha",
        "Music",
        "Mystery",
        "NSFW",
        "Office lady",
        "Parody",
        "Philosophical",
        "Psychological",
        "Romance",
        "School life",
        "Sci-fi",
        "Slice of life",
        "Sports",
        "Supernatural",
        "Tragedy",
        "Vampire",
        "Villainess",
        "Wholesome",
        "Witch",
        "Yaoi",
        "Yuri"
      ],
      "values": [
        "4_koma_1",
        "action",
        "adventure",
        "age_gap",
        "comedy",
        "college",
        "couple_life",
        "drama",
        "fantasy",
        "full_color",
        "gender_bender",
        "het",
        "historical",
        "horror",
        "idol",
        "isekai",
        "long_strip",
        "mahou_shoujo",
        "maid",
        "medieval",
        "mecha",
        "music",
        "mystery",
        "nsfw",
        "office_lady",
        "parody",
        "philosophical",
        "psychological",
        "romance",
        "school_life",
        "sci_fi",
        "slice_of_life",
        "sports",
        "supernatural",
        "tragedy",
        "vampire",
        "villainess",
        "wholesome",
        "witch",
        "yaoi",
        "yuri"
      ]
    }
  ],
  "endpoints": {
    "search": {
      "path": "/search",
      "isApi": false,
      "params": {
        "q": "{query}",
        "classes[]": "Series",
        "sort": "{Sort}",
        "with[]": "{Tag}",
        "page": "{page}"
      },
      "selector": {
        "list": "dl.chapter-list dd",
        "id": "a.name@href | regex:/\\/series\\/([^\\/]+)/",
        "title": "a.name",
        "coverUrl": ""
      },
      "nextPageSelector": ".pagination a[rel=next]"
    },
    "popular": {
      "path": "/search",
      "isApi": false,
      "params": {
        "classes[]": "Series",
        "sort": "views",
        "with[]": "{Tag}",
        "page": "{page}"
      },
      "selector": {
        "list": "dl.chapter-list dd",
        "id": "a.name@href | regex:/\\/series\\/([^\\/]+)/",
        "title": "a.name",
        "coverUrl": ""
      },
      "nextPageSelector": ".pagination a[rel=next]"
    },
    "latest": {
      "path": "/search",
      "isApi": false,
      "params": {
        "classes[]": "Series",
        "sort": "created_at",
        "with[]": "{Tag}",
        "page": "{page}"
      },
      "selector": {
        "list": "dl.chapter-list dd",
        "id": "a.name@href | regex:/\\/series\\/([^\\/]+)/",
        "title": "a.name",
        "coverUrl": ""
      },
      "nextPageSelector": ".pagination a[rel=next]"
    },
    "details": {
      "path": "/series/{seriesId}.json",
      "isApi": true,
      "mapping": {
        "id": "$.permalink",
        "title": "$.name",
        "coverUrl": "https://dynasty-scans.com{$.cover}",
        "description": "$.description",
        "author": "$.tags[?(@.type=='Author')].name",
        "status": "$.tags[?(@.type=='Status')].name",
        "tags": "$.tags[?(@.type=='General')]",
        "tagFormat": "{$.name}"
      }
    },
    "chapters": {
      "path": "/series/{seriesId}.json",
      "isApi": true,
      "mapping": {
        "list": "$.taggings[*]",
        "id": "$.permalink",
        "title": "$.title",
        "dateUploaded": "$.released_on"
      }
    },
    "pages": {
      "path": "/chapters/{chapterSlug}.json",
      "isApi": true,
      "mapping": {
        "pages": "$.pages[*].url",
        "pageUrl": "{baseUrl}{page}",
        "title": "$.long_title"
      }
    }
  }
}
